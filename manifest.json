{
    "manifest_version": 3,
    "name": "__MSG_extName__",
    "version": "2.25",
    "description": "__MSG_extDesc__",
    "default_locale": "en",
    "icons": {
        "16": "icons/16.png",
        "48": "icons/48.png",
        "128": "icons/128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/16.png",
            "48": "icons/48.png",
            "128": "icons/128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "permissions": [
        "activeTab",
        "scripting",
        "clipboardWrite",
        "storage",
        "downloads"
    ],
    "host_permissions": [
        "*://*.forgeofempires.com/*",
        "https://foehelp.ru/*",
        "https://api.telegram.org/*",
        "https://discord.com/api/webhooks/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "*://*.forgeofempires.com/*"
            ],
            "js": [
                "src/modules/wells/wells_content.js",
                "src/modules/planner/planner_content.js",
                "src/modules/medal/medal_content.js",
                "src/modules/telegram/telegram_content.js",
                "src/modules/statprod/statprod_content.js",
				"src/modules/qi-planner/qi_content.js",
				"src/modules/sg/sg_content.js",
				"src/modules/buildnum/buildnum_content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "src/modules/wells/wells_page.js",
                "src/modules/planner/cityplan.html",
                "src/modules/planner/cityplan.js",
                "src/modules/planner/planner_page.js",
                "src/modules/medal/medal_page.js",
                "src/modules/bubble/bubble.html",
                "src/modules/bubble/bubble.js",
                "src/modules/kits/kits.html",
                "src/modules/kits/kits.js",
                "src/modules/qi-planner/kvag.html",
                "src/modules/qi-planner/kvag.js",
				"src/modules/qi-planner/kvag_data.js",
                "kvaimg/*",
                "_locales/*",
                "src/modules/telegram/telegram.js",
                "src/modules/telegram/telegram.css",
                "src/modules/statprod/index.html",
                "src/modules/statprod/style.css",
                "src/modules/statprod/era_names.js",
                "src/modules/statprod/foe_analyzer.js",
                "src/modules/statprod/statprod_page.js",
                "src/modules/statprod/index.js",
                "src/modules/statbattle/indexst.html",
                "src/modules/statbattle/indexst.js",
                "src/modules/statbattle/foe_analyzerst.js",
                "src/modules/statbattle/era_names.js",
                "src/modules/statbattle/stylest.css",
				"src/modules/qi-planner/qi_page.js",
                "src/modules/qi-planner/kvag.html",
				"src/modules/sg/sg_page.js",
                "src/modules/sg/vstitan.html",
                "src/modules/sg/vstitan.js",
				"src/modules/buildnum/buildnum_page.js",
                "src/modules/buildnum/zdan.html",
                "src/modules/buildnum/zdan.js"
            ],
            "matches": [
                "*://*.forgeofempires.com/*"
            ]
        },
        {
            "resources": [
                "src/modules/8/index.html",
                "src/modules/8/style.css",
                "src/modules/8/physics.js",
                "src/modules/8/rules.js"
            ],
            "matches": ["<all_urls>"]
        },
        {
            "resources": [
                "src/modules/kra/index.html",
                "src/modules/kra/js/levels.js",
                "src/modules/kra/js/constants.js",
                "src/modules/kra/js/utils.js",
                "src/modules/kra/js/audio.js",
                "src/modules/kra/js/background1.js",
                "src/modules/kra/js/bonuses.js",
                "src/modules/kra/js/paddle.js",
                "src/modules/kra/js/pause-effects.js",
                "src/modules/kra/js/demo.js",
                "src/modules/kra/js/game.js",
                "src/modules/kra/js/events.js"
            ],
            "matches": ["<all_urls>"]
        }
    ]
}